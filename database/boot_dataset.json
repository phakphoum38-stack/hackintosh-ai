for i, d in enumerate(data):

    x = d.get("x", None)
    y = d.get("y", None)

    if x is None or y is None:
        print(f"skip {i}: missing x/y")
        continue

    if not isinstance(x, list):
        print(f"skip {i}: x not list -> {x}")
        continue

    if len(x) == 0:
        print(f"skip {i}: empty x")
        continue
